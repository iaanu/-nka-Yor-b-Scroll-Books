<section class="osp-wrap" aria-label="Ònka Yorùbá Scholarly Reference Panels">
<style>
/* ═════════════════════════════════════════════════════════════
   GLASSMORPHISM NEON — Scholarly Reference Section
═════════════════════════════════════════════════════════════ */
.osp-wrap{position:relative;overflow:hidden;background:linear-gradient(160deg,#141c32 0%,#111830 50%,#0e1a38 100%);padding:72px 28px 64px;font-family:'Poppins','Segoe UI',sans-serif;}
.osp-wrap::before{content:'';position:absolute;inset:0;background-image:radial-gradient(2px 2px at 15% 25%,rgba(255,215,0,0.3),transparent),radial-gradient(2px 2px at 45% 70%,rgba(255,19,240,0.25),transparent),radial-gradient(1px 1px at 75% 15%,rgba(37,99,235,0.4),transparent),radial-gradient(1px 1px at 85% 85%,rgba(255,215,0,0.2),transparent),radial-gradient(2px 2px at 55% 45%,rgba(147,51,234,0.2),transparent);animation:driftParticles 20s linear infinite;pointer-events:none;}
@keyframes driftParticles{0%{transform:translateY(0);}100%{transform:translateY(-30px);}}
.osp-wrap::after{content:'';position:absolute;bottom:0;left:10%;right:10%;height:2px;background:linear-gradient(90deg,transparent,#FFD700,#FF13F0,#2563EB,transparent);border-radius:2px;box-shadow:0 0 20px rgba(255,215,0,0.4),0 0 40px rgba(255,19,240,0.2);}
.osp-head{text-align:center;margin-bottom:42px;position:relative;z-index:1;}
.osp-head h3{color:#FFD700;font-size:.72rem;font-weight:800;letter-spacing:.22em;text-transform:uppercase;margin:0 0 8px;text-shadow:0 0 12px rgba(255,215,0,0.4);}
.osp-head p{color:rgba(255,255,255,.75);font-size:.78rem;margin:0;font-weight:400;}
.osp-divider{display:flex;align-items:center;gap:14px;max-width:440px;margin:0 auto 38px;position:relative;z-index:1;}
.osp-divider span{flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(255,215,0,0.5),transparent);}
.osp-divider em{color:rgba(255,255,255,.85);font-size:.62rem;font-style:normal;white-space:nowrap;letter-spacing:.08em;}
.osp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:26px;max-width:1220px;margin:0 auto;position:relative;z-index:1;}
.osp-card{background:rgba(255,255,255,0.05);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,0.12);border-radius:20px;padding:32px 28px;position:relative;overflow:hidden;transition:all .4s cubic-bezier(.4,0,.2,1);}
.osp-card:hover{border-color:rgba(255,215,0,0.5);box-shadow:0 8px 40px rgba(0,0,0,0.3),inset 0 1px 0 rgba(255,215,0,0.15);transform:translateY(-3px);}
.osp-card::before{content:'';position:absolute;top:0;left:24px;right:24px;height:2px;background:var(--card-accent,linear-gradient(90deg,#FFD700,#FF13F0));border-radius:0 0 4px 4px;opacity:.7;transition:opacity .3s;}
.osp-card:hover::before{opacity:1;}
.osp-card:nth-child(1){--card-accent:linear-gradient(90deg,#FF13F0,#9333EA);}
.osp-card:nth-child(2){--card-accent:linear-gradient(90deg,#FFD700,#EF6000);}
.osp-card:nth-child(3){--card-accent:linear-gradient(90deg,#2563EB,#0891B2);}
.osp-icon{font-size:1.8rem;display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:14px;background:rgba(255,255,255,0.07);margin-bottom:14px;}
.osp-label{color:#FFD700;font-size:.66rem;font-weight:800;letter-spacing:.18em;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.12);padding-bottom:12px;margin-bottom:18px;}
.osp-keytbl{width:100%;border-collapse:collapse;}
.osp-keytbl tr+tr td{border-top:1px solid rgba(255,255,255,0.08);}
.osp-keytbl td{padding:9px 0;font-size:.79rem;vertical-align:top;}
.osp-ksym{color:#FF13F0;font-weight:700;padding-right:16px;min-width:72px;white-space:nowrap;font-size:.78rem;}
.osp-kdesc{color:rgba(255,255,255,.88);line-height:1.6;}
.osp-cite{background:rgba(255,215,0,0.04);border-left:3px solid #FFD700;border-radius:0 12px 12px 0;padding:16px 18px;font-size:.82rem;color:rgba(255,255,255,.92);line-height:1.75;font-style:italic;}
.osp-cite strong{color:#FFD700;font-style:normal;}
.osp-cite-meta{margin-top:12px;font-size:.7rem;color:rgba(255,255,255,.6);font-style:normal;padding-top:10px;border-top:1px solid rgba(255,255,255,0.08);}
.osp-badge{display:inline-block;background:linear-gradient(90deg,#A855F7,#2563EB);color:#fff;font-size:.6rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;padding:4px 14px;border-radius:20px;margin-bottom:14px;box-shadow:0 2px 12px rgba(168,85,247,0.3);}
.osp-api-p{color:rgba(255,255,255,.88);font-size:.82rem;line-height:1.72;}
.osp-api-p strong{color:#fff3b0;}
.osp-endpoint{margin-top:14px;background:rgba(0,0,0,0.35);border:1px solid rgba(255,255,255,0.15);border-radius:10px;padding:12px 16px;font-family:'Courier New',monospace;font-size:.74rem;color:#7FDBCA;letter-spacing:.03em;line-height:1.7;}
.osp-arrow{color:#FF13F0;}
</style>

<div class="osp-head">
  <h3>Ètò Ìmọ̀ Ònkà Yorùbá &nbsp;·&nbsp; Scholarly Reference</h3>
  <p>Academic standards documentation for the New Ònkà Yorùbá Numeric System</p>
</div>
<div class="osp-divider">
  <span></span><em>◆ Ìwé Ìmọ̀ Ònkà ◆</em><span></span>
</div>

<div class="osp-grid">

  <!-- ① TABLE CLASSIFICATION KEY -->
  <div class="osp-card">
    <span class="osp-icon">🔑</span>
    <div class="osp-label">Table Classification Key</div>
    <table class="osp-keytbl" aria-label="Column guide for Ònka Yorùbá tables">
      <tbody><tr>
        <td class="osp-ksym">Symbol</td>
        <td class="osp-kdesc">Scientific exponential representation of the number''s magnitude</td>
      </tr>
      <tr>
        <td class="osp-ksym">Name</td>
        <td class="osp-kdesc">Official Ònka Yorùbá index terminology — the canonical Yoruba Numerical Lexicon form</td>
      </tr>
      <tr>
        <td class="osp-ksym">Scale</td>
        <td class="osp-kdesc">Power-of-ten magnitude — e.g., 10³ = Thousands tier, 10&sup6; = Millions tier</td>
      </tr>
      <tr>
        <td class="osp-ksym">Tier</td>
        <td class="osp-kdesc">Hierarchical classification level within the 47-Sovereign Colour Visual Protocol</td>
      </tr>
      <tr>
        <td class="osp-ksym"><span style="color:#FF13F0;font-weight:700;">l</span> Link</td>
        <td class="osp-kdesc">The <em>l</em> multiplier connector — displayed in neon pink (#FF13F0), the engine of infinite magnitude chaining</td>
      </tr>
    </tbody></table>
  </div>

  <!-- ② CITATION STATEMENT -->
  <div class="osp-card">
    <span class="osp-icon">📜</span>
    <div class="osp-label">Cite This Work</div>
    <div class="osp-cite">
      <strong>Ònka Yorùbá Institute</strong> (2026).
      <em>Yoruba Numerical Index Database, v1.0.</em>
      Godreign Digital Publishing.
      <em>Ètò Ìmọ̀ Ònkà Yorùbá — The New Ònkà Yorùbá Numeric System.</em>
      <div class="osp-cite-meta">
        ISBN (979-8-90148-351-0) &nbsp;·&nbsp;
        Freely accessible for academic, educational &amp; research use &nbsp;·&nbsp;
        © 2026 Godreign. The Universal Hyperdimensional Numeric Engine.
      </div>
    </div>
  </div>

  <!-- ③ FUTURE API NOTICE -->
  <div class="osp-card">
    <span class="osp-icon">⚡</span>
    <div class="osp-label">Developer API Notice</div>
    <span class="osp-badge">Coming Soon</span>
    <p class="osp-api-p">
      Public API access to the <strong>Yoruba Numerical Index Database</strong> is planned for a future
      release, enabling developers, researchers, and digital platforms worldwide to programmatically
      query over a <strong>tredecillion</strong> Yorùbá number entries in real time.
    </p>
    <div class="osp-endpoint">
      GET /api/v1/onka-yoruba/number/{n}<br>
      <span class="osp-arrow">→</span>&nbsp;{ yoruba: "…", tier: "…", colour: "…", power: "…" }
    </div>
  </div>

</div>
</section>

  <footer>
    <div class="footer-content">
      <span class="copyright">&copy; 2026 Godreign. The Universal Hyperdimensional Numeric Engine.</span>

    <p class="english-mission">
        Honouring every people's numerical heritage &mdash; building an open, language-independent path to global computational equity.
      </p>
    </div>
  </footer>
  </div>
  <!-- /.container -->

  <button class="back-to-top" id="backToTop" title="Back to Top" aria-label="Scroll to top">▲</button>

  <script>
    // Scroll progress
    const progressBar = document.getElementById('scrollProgress');
    const topBtn = document.getElementById('backToTop');
    window.addEventListener('scroll', () => {
      const s = document.documentElement.scrollTop || document.body.scrollTop;
      const h = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      progressBar.style.width = (h > 0 ? (s / h) * 100 : 0) + '%';
      if (window.scrollY > 600) topBtn.classList.add('visible'); else topBtn.classList.remove('visible');
    }, { passive: true });
    topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // Live table search
    const searchBox = document.getElementById('searchBox');
    const stats = document.getElementById('searchStats');
    const langSelect = document.getElementById('langSelect');
    const soonNotice = document.getElementById('soonNotice');
    const rows = Array.from(document.querySelectorAll('#masterBody tr'));
    const TOTAL = rows.length;

    function applyFilter() {
      const q = searchBox.value.trim().toLowerCase();
      let shown = 0;
      for (const r of rows) {
        const match = !q || r.textContent.toLowerCase().includes(q);
        r.classList.toggle('hidden', !match);
        if (match) shown++;
      }
      stats.innerHTML = '<strong>' + shown + '</strong> of ' + TOTAL + ' entries shown' + (q ? ' &middot; filter: <em>' + q.replace(/[<>&]/g,'') + '</em>' : ' &middot; Type to filter in real time.');
    }

    searchBox.addEventListener('input', applyFilter);

    // Language selector — Yorùbá is live; others show a friendly "coming soon" notice.
    langSelect.addEventListener('change', () => {
      const opt = langSelect.options[langSelect.selectedIndex];
      const code = langSelect.value;
      const label = opt.textContent.replace(/\s*—.*$/, '').trim();
      if (code === 'yo') {
        soonNotice.classList.remove('show');
        soonNotice.innerHTML = '';
        searchBox.disabled = false;
        searchBox.placeholder = 'Search by Yorùbá name, English name, root, or row number…';
        applyFilter();
      } else {
        // Show coming-soon banner; keep Yorùbá table visible underneath.
        soonNotice.innerHTML = '🌐 <strong>' + label + '</strong> is joining the atlas soon. ' +
          'Until then, the <strong>Yorùbá Master Index (833 entries)</strong> is shown below as the live reference. ' +
          'Want to help build the <em>' + label + '</em> dataset? ' +
          '<a href="mailto:godreigninlove@outlook.com?subject=Contribute%20' + encodeURIComponent(label) + '%20Numerals" style="color:#0f3460; font-weight:700;">Contribute here →</a>';
        soonNotice.classList.add('show');
        searchBox.disabled = false;
        searchBox.placeholder = 'Search the Yorùbá reference table while ' + label + ' is being prepared…';
      }
    });

    // Chromatic Chord theme switcher (Region ⇄ Yorùbá Vowel)
    document.querySelectorAll('.theme-toggle .t-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const theme = btn.dataset.theme;
        document.body.classList.toggle('theme-vowel', theme === 'vowel');
        document.querySelectorAll('.theme-toggle .t-btn').forEach(b => {
          const active = (b === btn);
          b.classList.toggle('active', active);
          b.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      });
    });
  </script>
</body>
</html>
